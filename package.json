{
  "name": "my-pi-web",
  "version": "1.0.0",
  "description": "Pi Agent Web UI - 语音输入、文件编辑、会话缓存增强的 pi 网页界面",
  "license": "MIT",
  "bin": {
    "pi-web": "bin/pi-web.js"
  },
  "files": [
    "bin",
    ".next",
    "!.next/cache",
    "!.next/dev",
    "!.next/**/*.js.map",
    "public",
    "next.config.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev -p 9527",
    "build": "next build",
    "start": "next start -p 9527",
    "lint": "eslint .",
    "release": "npm version patch --no-git-tag-version && npm run build && npm publish --access public"
  },
